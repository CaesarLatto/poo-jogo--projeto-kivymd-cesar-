ScreenManager:
    MenuScreen:
    BoardScreen:
    ResultScreen:

<MenuScreen>:
    name: "menu"
    MDBoxLayout:
        orientation: "vertical"
        spacing: "20dp"
        padding: "20dp"
        size_hint: 1, 1

        MDCard:
            orientation: "vertical"
            spacing: "20dp"
            padding: "20dp"
            size_hint: 0.9, None
            height: "400dp"
            pos_hint: {"center_x": 0.5}
            md_bg_color: 1, 1, 1, 1

            MDLabel:
                text: "Jogo da Velha"
                halign: "center"
                font_style: "H3"
                size_hint_y: None
                height: "50dp"

            MDTextField:
                id: player1
                hint_text: "Nome do Jogador 1"
                text: "Jogador X"
                required: True
                helper_text_mode: "on_error"
                mode: "rectangle"
                size_hint_x: 0.9
                pos_hint: {"center_x": 0.5}

            MDTextField:
                id: player2
                hint_text: "Nome do Jogador 2"
                text: "Jogador O"
                required: True
                helper_text_mode: "on_error"
                mode: "rectangle"
                size_hint_x: 0.9
                pos_hint: {"center_x": 0.5}

            MDRaisedButton:
                text: "Começar Jogo"
                icon: "play"
                size_hint_x: 0.8
                pos_hint: {"center_x": 0.5}
                on_release: app.start_game()
                md_bg_color: 0.2, 0.6, 0.9, 1

<BoardScreen>:
    name: "board"
    MDBoxLayout:
        orientation: "vertical"
        padding: "8dp"
        spacing: "12dp"
        size_hint: 1, 1

        # Barra superior com botão para voltar ao menu
        MDTopAppBar:
            title: "Partida do Jogo da Velha"
            anchor_title: "left"
            left_action_items: [["arrow-left", lambda x: root.voltar_menu()]]
            elevation: "4dp"

        # Card com informações do turno
        MDCard:
            orientation: "horizontal"
            spacing: "12dp"
            padding: "12dp"
            size_hint_y: None
            height: "50dp"
            md_bg_color: 0.2, 0.8, 0.6, 1

            MDLabel:
                id: label_turno
                text: "Turno: Jogador X"
                halign: "center"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1

        # Card para mensagem de resultado/erro
        MDCard:
            id: result_card
            orientation: "vertical"
            padding: "12dp"
            spacing: "8dp"
            size_hint_y: None
            height: "50dp"
            md_bg_color: 0.95, 0.3, 0.3, 0.8

            MDLabel:
                id: label_result
                text: ""
                halign: "center"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                font_style: "Body1"

        # Centraliza a grade do tabuleiro na tela (responsivo)
        AnchorLayout:
            anchor_x: "center"
            anchor_y: "center"
            size_hint: 1, 0.7

            MDGridLayout:
                id: grid_tabuleiro
                cols: 3
                rows: 3
                size_hint: None, None
                size: "280dp", "280dp"
                spacing: "8dp"

        # Botões de ação
        MDBoxLayout:
            size_hint_y: None
            height: "50dp"
            spacing: "12dp"
            padding: "8dp"

            MDRaisedButton:
                text: "Reiniciar"
                icon: "restart"
                on_release: root.reset_board()
                md_bg_color: 0.9, 0.6, 0.2, 1
                size_hint_x: 0.5

            MDRaisedButton:
                text: "Voltar"
                icon: "arrow-left"
                on_release: root.voltar_menu()
                md_bg_color: 0.5, 0.5, 0.5, 1
                size_hint_x: 0.5

<ResultScreen>:
    name: "result"
    MDBoxLayout:
        orientation: "vertical"
        spacing: "20dp"
        padding: "20dp"
        size_hint: 1, 1

        MDTopAppBar:
            title: "Resultado"
            anchor_title: "left"
            left_action_items: [["arrow-left", lambda x: root.voltar_menu()]]

        MDCard:
            orientation: "vertical"
            spacing: "20dp"
            padding: "20dp"
            size_hint: 0.9, 0.7
            pos_hint: {"center_x": 0.5}
            md_bg_color: 1, 1, 1, 1

            MDLabel:
                id: result_title
                text: "Jogo Finalizado!"
                halign: "center"
                font_style: "H3"
                size_hint_y: None
                height: "60dp"

            MDLabel:
                id: result_message
                text: ""
                halign: "center"
                font_style: "H4"
                size_hint_y: None
                height: "80dp"

        MDBoxLayout:
            size_hint_y: None
            height: "50dp"
            spacing: "12dp"
            padding: "8dp"

            MDRaisedButton:
                text: "Jogar Novamente"
                icon: "restart"
                on_release: app.restart_game()
                md_bg_color: 0.2, 0.8, 0.6, 1

            MDFlatButton:
                text: "Menu Principal"
                on_release: app.go_to_menu()